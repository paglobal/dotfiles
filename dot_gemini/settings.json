{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "disableYoloMode": true
  },
  "general": {
    "previewFeatures": true,
    "vimMode": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "warningAcknowledged": true
    },
    "preferredEditor": "neovim"
  },
  "output": {
    "format": "text"
  },
  "ui": {
    "showStatusInTitle": true
  },
  "hooks": {
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "instruction-reinforcer",
            "type": "command",
            "command": "~/.gemini/hooks/reinforce-instructions/reinforce-instructions.nu",
            "description": "Reinforces instructions present in the global user GEMINI.md file"
          }
        ]
      }
    ]
  }
}